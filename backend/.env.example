# ============================================================
# 背单词 App - 环境变量配置
# 复制为 .env 文件后填入实际值
# ============================================================

# ---- 数据库（阿里云 RDS PostgreSQL） ----
DATABASE_URL=postgresql+asyncpg://username:password@your-rds-endpoint.aliyuncs.com:5432/wordbook_db

# ---- JWT 认证 ----
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080    # 7天

# ---- 阿里云 OSS（存储发音音频） ----
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=wordbook-audio
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_DOMAIN=https://wordbook-audio.oss-cn-shanghai.aliyuncs.com

# ---- 通义千问 API ----
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- Ollama 本地 AI（开发环境用） ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# ---- 有道 TTS ----
YOUDAO_APP_KEY=your-app-key
YOUDAO_APP_SECRET=your-app-secret

# ---- 应用配置 ----
APP_ENV=development    # development / production
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
